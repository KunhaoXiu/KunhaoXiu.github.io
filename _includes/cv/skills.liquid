{% comment %}
  Unified skills entry renderer for both formats
{% endcomment %}

<div class="card-text font-weight-light">
  {% for entry in entries %}
    <div class="skill-item">
      <div class="skill-heading">
        {% if entry.icon %}
          <i class="{{ entry.icon }}"></i>
        {% endif %}
        <strong>
          {{- entry.name | default: entry.label -}}
          {%- if entry.level %} ({{ entry.level }}){% endif %}:</strong
        >
      </div>
      {% if entry.keywords %}
        <ul class="skill-keywords mb-0">
          {% for keyword in entry.keywords %}
            <li>{{ keyword }}</li>
          {% endfor %}
        </ul>
      {% elsif entry.details %}
        <p class="skill-details mb-0">{{ entry.details }}</p>
      {% endif %}
    </div>
  {% endfor %}
</div>

<style>
  .skill-item {
    padding: 0.75rem 0;
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
  }

  .skill-heading {
    margin-bottom: 0.4rem;
  }

  .skill-keywords {
    margin-left: 1.5rem;
    padding-left: 1rem;
  }

  .skill-keywords li {
    margin-bottom: 0.35rem;
    line-height: 1.5;
  }

  .skill-details {
    line-height: 1.6;
    color: rgba(0, 0, 0, 0.78);
  }

  .skill-item:last-child {
    border-bottom: 0;
  }
</style>
