{% comment %}
  Unified interests entry renderer for both formats
{% endcomment %}

<div class="card-text font-weight-light">
  {% for entry in entries %}
    <div class="interest-item">
      <div class="interest-heading">
        {% if entry.icon %}
          <i class="{{ entry.icon }}"></i>
        {% endif %}
        <strong>{{ entry.name }}:</strong>
      </div>
      {% if entry.keywords %}
        <ul class="interest-keywords mb-0">
          {% for keyword in entry.keywords %}
            <li>{{ keyword }}</li>
          {% endfor %}
        </ul>
      {% endif %}
    </div>
  {% endfor %}
</div>

<style>
  .interest-item {
    padding: 0.5rem 0;
  }

  .interest-heading {
    margin-bottom: 0.35rem;
  }

  .interest-keywords {
    margin-left: 1.5rem;
    padding-left: 1rem;
  }
</style>
